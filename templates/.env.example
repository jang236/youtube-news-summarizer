# 🎬 강화된 YouTube 영상 분석기 - Environment Variables
# Replit 환경에서 이 파일을 .env로 복사하고 실제 API 키를 입력하세요

# 🔑 Google Gemini API 키 (필수)
# https://aistudio.google.com/ 에서 발급 받으세요
GEMINI_API_KEY=your_gemini_api_key_here

# 🔑 YouTube Data API v3 키 (선택사항, 영상 정보 향상용)
# https://console.cloud.google.com/ 에서 발급 받으세요
YOUTUBE_API_KEY=your_youtube_api_key_here

# 🔒 Flask Secret Key (보안용, 임의의 길고 복잡한 문자열)
SECRET_KEY=your_very_long_and_complex_secret_key_here_for_session_security

# 🌐 배포 설정
# Replit에서는 PORT가 자동 설정되므로 일반적으로 수정 불필요
# PORT=5000

# 📝 로깅 레벨 (선택사항)
# LOG_LEVEL=INFO

# 🎤 Whisper 모델 크기 설정 (선택사항)
# tiny(빠름) < base(기본) < small < medium < large(정확함)
# WHISPER_MODEL_SIZE=tiny